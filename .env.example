# LLM - 阿里云百炼 (DashScope，OpenAI 兼容)
ALIYUN_API_KEY=sk-xxxx
ALIYUN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ALIYUN_MODEL=qwen-plus

# LLM - DeepSeek
DEEPSEEK_API_KEY=sk-xxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# LLM - OpenAI (可选)
OPENAI_API_KEY=sk-xxxx
OPENAI_DEFAULT_MODEL=gpt-4o

# LLM - Ollama 本地 (可选)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=qwen2.5:7b

# 默认 LLM 提供商: aliyun / deepseek / openai / ollama
DEFAULT_LLM_PROVIDER=aliyun

# Embedding 模型
EMBEDDING_MODEL_NAME=paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DEVICE=cpu

# Database (SQLite 开发 / PostgreSQL 生产)
DATABASE_URL=sqlite+aiosqlite:///./data/app.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/ragkb

# Redis
REDIS_URL=redis://localhost:6379/0

# ChromaDB
CHROMA_PERSIST_DIR=./data/chroma

# JWT
JWT_SECRET_KEY=change-me-to-a-random-secret-key-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
CORS_ORIGINS=http://localhost:5173

# 文件上传
MAX_UPLOAD_SIZE_MB=20

# 文档分块
CHUNK_SIZE=500
CHUNK_OVERLAP=50
RETRIEVAL_TOP_K=8

# 限流
RATE_LIMIT_ENABLED=true

# 用户注册开关
ALLOW_REGISTRATION=true

# 应用
APP_NAME=RAG 知识库问答系统
DEBUG=true
LOG_LEVEL=INFO
